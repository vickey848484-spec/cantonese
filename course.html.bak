<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>揾啱你嘅课 · 識讲粤语</title>
  <link rel="stylesheet" href="css/style.css?v=20260607b">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body>
  <main class="container container-wide">
    <section class="section">
      <div class="center mb-3">
        <h1 class="display"><i data-icon="book-open"></i> 揾啱你嘅课</h1>
        <p class="muted mt-1" id="subtitle">按你嘅等级 + 性格筛嘅</p>
      </div>

      <div class="card-flat mb-3 hide" id="no-result">
        <p>你未测试过 <a href="test.html" style="color: var(--blue);">→ 去测一测</a></p>
      </div>

      <h2 class="display" style="font-size: 22px;" id="sec1-title"><i data-icon="star"></i> 主推</h2>
      <div id="course-list" class="grid grid-3 mt-2 mb-3"></div>

      <h2 class="display mt-3" style="font-size: 22px;" id="sec2-title">更多选择</h2>
      <div id="course-list-more" class="grid grid-3 mt-2"></div>

      <div class="center mt-3">
        <a class="btn btn-ghost" href="result.html">← 睇返结果</a>
        <a class="btn btn-primary" href="signup.html">下一步：留邮箱 →</a>
      </div>
    </section>
  </main>

  <footer class="footer">識讲粤语 · 由 Vickey 老师主理</footer>

  <script src="js/common.js?v=20260607b"></script>
  <script src="js/labeler.js?v=20260607b"></script>
  <script>
    Cantonese.initTheme();
    Cantonese.injectThemeToggle();
    Cantonese.injectTopbar('course');
    Cantonese.initIcons();
    Cantonese.initScrollReveal();

    (async function () {
      const result = Cantonese.Store.get(Cantonese.Store.KEYS.result);
      if (!result) {
        document.getElementById('no-result').classList.remove('hide');
        document.getElementById('course-list').innerHTML = '';
        document.getElementById('course-list-more').innerHTML = '';
        return;
      }

      const { level, mbtiCode } = result;
      const mbtiType = await Labeller.load().then(() => Labeller.resolve(mbtiCode));
      const matchTags = (mbtiType && mbtiType.matchTags) || [];

      const { courses } = await Cantonese.loadJSON('data/courses.json');

      const scored = courses.map(c => {
        let score = 0;
        if (c.level === level.short) score += 10;
        c.tags.forEach(t => { if (matchTags.includes(t)) score += 3; });
        return { ...c, _score: score };
      }).sort((a, b) => b._score - a._score);

      const main = scored.slice(0, 3);
      const more = scored.slice(3);

      document.getElementById('subtitle').textContent =
        `按你嘅「${level.name}」+ 「${mbtiCode}」筛嘅 ${scored.length} 门`;

      const badgeClass = level.key === 'entry' ? 'badge-blue'
                       : level.key === 'mid'   ? 'badge-pink'
                       : 'badge-purple';

      function renderCard(c) {
        return `
          <div class="course-card">
            <i class="course-emoji">${Cantonese.icon(c.icon || 'book-open')}</i>
            <div class="row" style="gap:6px;">
              <span class="${badgeClass}" style="padding: 2px 10px; border-radius: 999px; font-size: 12px; font-weight: 700;">${c.level}</span>
              ${c.tags.map(t => `<span class="tag">${t}</span>`).join('')}
            </div>
            <div class="bold">${c.title}</div>
            <p class="course-highlight">${c.highlight}</p>
            <div class="row" style="justify-content: space-between; align-items: center;">
              <div class="text-sm muted">${c.type} · ${c.duration}</div>
              <div class="bold" style="color: var(--pink); font-size: 18px;">${c.price}</div>
            </div>
            <a class="btn btn-primary btn-block" href="${c.link}" target="_blank">查看课程 ${Cantonese.icon('arrow-right')}</a>
          </div>
        `;
      }

      document.getElementById('course-list').innerHTML = main.map(renderCard).join('');
      document.getElementById('course-list-more').innerHTML = more.map(renderCard).join('');
    })();
  </script>
</body>
</html>
